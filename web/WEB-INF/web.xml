<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <listener>
    <listener-class>listener.AppContextListener</listener-class>
</listener>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>OtpVerificationServlet</servlet-name>
        <servlet-class>controller.OtpVerificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>OtpVerificationServlet</servlet-name>
        <url-pattern>/OtpVerificationServlet</url-pattern>
    </servlet-mapping>
 

    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
